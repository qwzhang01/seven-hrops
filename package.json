{
  "name": "seven-hrops",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --coverage",
    "test:sandbox": "vitest run src/platform/sandbox/tests/sandbox-stress.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:cargo": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:cargo",
    "test:route-eval": "vitest run --config vitest.route-eval.config.ts tests/route-eval/router.test.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "codegen:schema": "cargo run --manifest-path src-tauri/Cargo.toml --bin gen_manifest_schema",
    "codegen:types": "node scripts/gen-manifest-types.mjs",
    "codegen": "pnpm run codegen:schema && pnpm run codegen:types",
    "codegen:check": "pnpm run codegen && git diff --exit-code platform/schemas src/types/manifest.generated.ts",
    "check:aisdk-versions": "tsx scripts/check-aisdk-versions.ts",
    "check:aisdk-smoke": "tsx scripts/aisdk-mixed-version-smoke.ts",
    "check:prompt-style-smoke": "tsx scripts/prompt-style-decorator-smoke.ts",
    "check:dynamic-provider-safety": "tsx scripts/check-dynamic-provider-safety.ts",
    "check:registry-routing": "tsx scripts/check-registry-routing.ts"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.25",
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/cohere": "^3.0.36",
    "@ai-sdk/deepinfra": "^2.0.52",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/perplexity": "^3.0.33",
    "@ai-sdk/togetherai": "^2.0.53",
    "@ai-sdk/xai": "^3.0.93",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.80.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@types/dompurify": "^3.0.5",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "dompurify": "^3.4.5",
    "effect": "4.0.0-beta.65",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.511.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.2",
    "yaml": "^2.8.4",
    "zod": "^3.24.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
