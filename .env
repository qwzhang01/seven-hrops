# Email client feature flag
# Set to "true" to enable email client features (inbox, composer, email skills)
VITE_ENABLE_EMAIL=true

# OAuth configuration (required for Gmail/Outlook OAuth login)
# Register your app at Google Cloud Console / Azure Portal
VITE_OAUTH_CLIENT_ID=
VITE_OAUTH_SECRET_OR_TENANT=

# ─── Phase G: Orchestrator / WeChat Work (企微) Integration ──────────────────
# Enable the orchestrator feature (webhook listener + orchestrator agent).
# Default: false (disabled in local dev to avoid accidental webhook port exposure).
ORCHESTRATOR_ENABLED=

# WeChat Work webhook token for HMAC-SHA256 signature verification.
# Set this to the secret token configured in your WeChat Work bot settings.
WECOM_WEBHOOK_TOKEN=

# Default WeChat Work bot ID for outbound messages via send_wecom_message tool.
WECOM_BOT_ID=

# Comma-separated list of allowed WeChat Work bot IDs (whitelist).
# Only bots in this list can be used by send_wecom_message.
# Example: WECOM_ALLOWED_BOTS=bot-id-1,bot-id-2
WECOM_ALLOWED_BOTS=

