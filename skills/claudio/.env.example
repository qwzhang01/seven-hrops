# ============================================
# LLM 配置（支持 Anthropic / OpenAI 两种协议）
# ============================================
# 协议类型：anthropic 或 openai（必填）
LLM_PROTOCOL=anthropic

# API 密钥（必填，Ollama 可填任意值如 ollama）
LLM_API_KEY=your_api_key_here

# 接口地址（选填，不填则使用各协议默认值）
LLM_BASE_URL=

# 模型名称（必填）
LLM_MODEL=claude-sonnet-4-20250514

# ============================================
# 常用 Provider 配置示例
# ============================================
# --- Anthropic 官方 ---
# LLM_PROTOCOL=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-20250514

# --- 硅基流动 (SiliconFlow) ---
# LLM_PROTOCOL=openai
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# --- 火山云 ARK ---
# LLM_PROTOCOL=anthropic
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=ep-xxxxxxxx

# --- 阿里云 DashScope ---
# LLM_PROTOCOL=openai
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- 腾讯云 TI ---
# LLM_PROTOCOL=anthropic
# LLM_BASE_URL=https://api.lke.tencentcloudapi.com/v1
# LLM_MODEL=<模型ID>

# --- GLM 智谱 ---
# LLM_PROTOCOL=anthropic
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-plus

# --- Ollama（本地）---
# LLM_PROTOCOL=openai
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# 网易云音乐 API（需本地运行 NeteaseCloudMusicApi 服务）
# 留空则使用默认值 http://localhost:3001
NETEASE_API_BASE=
NETEASE_API_PORT=3001

# Fish Audio TTS
FISH_API_KEY=your_fish_audio_api_key_here
FISH_VOICE_ID=your_preferred_voice_id

# 天气 API（优先使用和风天气，国内访问更稳定）
# 和风天气：https://dev.qweather.com/ 注册免费获取 Key
QWEATHER_API_KEY=
# OpenWeather（备选）
OPENWEATHER_API_KEY=your_openweather_api_key_here
WEATHER_CITY=Shanghai

# 服务器配置
PORT=3000
HOST=localhost
